# ─── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
build/
out/
!gradle/wrapper/gradle-wrapper.properties

# ─── Java / Spring Boot ───────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
# Un-ignore the Gradle wrapper jar — it must be committed so CI can bootstrap Gradle
# This negation MUST appear after *.jar, otherwise *.jar overrides it
!gradle/wrapper/gradle-wrapper.jar
hs_err_pid*
replay_pid*

# Exception: Gradle wrapper jar MUST be committed so CI can bootstrap without installing Gradle
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ─── IntelliJ IDEA ────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws

# ─── VS Code ──────────────────────────────────────────────────────────────────
.vscode/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Node / React / Expo ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
dist/
.next/
.expo/
.expo-shared/
web-build/
*.tsbuildinfo

# ─── Docker ───────────────────────────────────────────────────────────────────
docker/volumes/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Terraform / Cloud ────────────────────────────────────────────────────────
*.tfstate
*.tfstate.backup
.terraform/

