# Copy to .env and fill in your values — NEVER commit .env to git!

# ─── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── JWT (generate with: openssl rand -hex 64) ─────────────────────────────────
JWT_SECRET=generate_256_bit_random_hex
JWT_REFRESH_SECRET=generate_another_256_bit_random_hex

# ─── Encryption (generate with: openssl rand -hex 32) ──────────────────────────
ENCRYPTION_KEY=generate_32_byte_aes_key_hex

# ─── OAuth2 Google ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_minio_password

# ─── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ─── Expo Push Notifications ───────────────────────────────────────────────────
EXPO_PUSH_TOKEN_SECRET=your_expo_push_secret

# ─── External Food APIs (free) ─────────────────────────────────────────────────
# Get free key at: https://api.nal.usda.gov
USDA_API_KEY=your_usda_api_key
# Open Food Facts needs no key

# ─── Observability ─────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── Frontend (web/.env) ───────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_DEFAULT_LANGUAGE=en

# ─── Mobile (mobile/.env — Expo) ───────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
