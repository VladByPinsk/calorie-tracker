<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>

  <!--
    MapStruct-generated mapper implementations.
    These are auto-generated by the annotation processor — do not lint them.
  -->
  <suppress files=".*MapperImpl\.java" checks=".*"/>

  <!--
    Lombok-generated builder inner classes can trigger HideUtilityClassConstructor
    and similar design checks.
  -->
  <suppress files=".*" checks="HideUtilityClassConstructor"/>

  <!--
    Test classes: relax Javadoc, magic-number, and method-name rules.
    Test method names like shouldReturnUser_whenUserExists() contain underscores.
  -->
  <suppress files=".*Test\.java"  checks="JavadocMethod|MagicNumber|MethodName"/>
  <suppress files=".*IT\.java"    checks="JavadocMethod|MagicNumber|MethodName"/>
  <suppress files=".*Tests\.java" checks="JavadocMethod|MagicNumber|MethodName"/>

  <!--
    Spring Boot @SpringBootApplication entry-point classes.
    They are one-liners — no Javadoc needed.
  -->
  <suppress files=".*Application\.java" checks="JavadocMethod"/>

</suppressions>

